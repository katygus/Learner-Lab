{
  "name": "strategy-library",
  "version": "1.0.0",
  "description": "Full-stack strategy library application with React frontend and Node.js backend",
  "main": "index.js",
  "scripts": {
    "client": "cd client && npm run dev",
    "server": "cd server && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-all": "npm install && cd client && npm install && cd ../server && npm install",
    "build": "cd client && npm run build",
    "start": "cd server && npm start",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/katygus/Strategy-Library.git"
  },
  "keywords": ["strategy", "library", "full-stack", "react", "node"],
  "author": "Katy Wells",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/katygus/Strategy-Library/issues"
  },
  "homepage": "https://github.com/katygus/Strategy-Library#readme",
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}